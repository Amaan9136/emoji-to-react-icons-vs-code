{
  "name": "emoji-to-react-icons",
  "displayName": "Emoji to React Icons",
  "description": "Instantly replace emoji in JSX/TSX with react-icons components. Scans files, auto-imports, and replaces 150+ emoji — with one command.",
  "version": "0.0.6",
  "publisher": "AmaanMohammadKhalander",
  "icon": "icon.png",
  "changelog": "CHANGELOG.md",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "emoji",
    "react-icons",
    "jsx",
    "tsx",
    "react",
    "icons",
    "replace emoji",
    "emoji to icons",
    "emoji converter",
    "react components",
    "font awesome",
    "fa6",
    "icon replacement",
    "emoji scanner",
    "jsx icons",
    "nextjs",
    "typescript"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/visual-studio-marketplace/v/AmaanMohammadKhalander.emoji-to-react-icons",
      "href": "https://marketplace.visualstudio.com/items?itemName=AmaanMohammadKhalander.emoji-to-react-icons",
      "description": "VS Code Marketplace Version"
    },
    {
      "url": "https://img.shields.io/visual-studio-marketplace/d/AmaanMohammadKhalander.emoji-to-react-icons",
      "href": "https://marketplace.visualstudio.com/items?itemName=AmaanMohammadKhalander.emoji-to-react-icons",
      "description": "VS Code Marketplace Downloads"
    }
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "emojiToReactIcons.scanCurrentFile",
        "title": "Emoji to React Icons: Scan Current File",
        "icon": "$(search)"
      },
      {
        "command": "emojiToReactIcons.replaceCurrentFile",
        "title": "Emoji to React Icons: Replace Emoji in Current File",
        "icon": "$(replace)"
      },
      {
        "command": "emojiToReactIcons.replaceSelection",
        "title": "Emoji to React Icons: Replace Emoji in Selection",
        "icon": "$(replace-all)"
      },
      {
        "command": "emojiToReactIcons.scanWorkspace",
        "title": "Emoji to React Icons: Scan Entire Workspace",
        "icon": "$(folder-opened)"
      },
      {
        "command": "emojiToReactIcons.replaceWorkspace",
        "title": "Emoji to React Icons: Replace Emoji in Entire Workspace",
        "icon": "$(run-all)"
      },
      {
        "command": "emojiToReactIcons.showEmojiMap",
        "title": "Emoji to React Icons: Show Full Emoji to Icon Map",
        "icon": "$(list-unordered)"
      },
      {
        "command": "emojiToReactIcons.addIgnoreEntry",
        "title": "Emoji to React Icons: Add to .emoji-ignore",
        "icon": "$(exclude)"
      }
    ],
    "configuration": {
      "title": "Emoji to React Icons",
      "properties": {
        "emojiToReactIcons.autoScan": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan the workspace for emoji once on startup and update diagnostics on save."
        },
        "emojiToReactIcons.hideUnsupportedInScan": {
          "type": "boolean",
          "default": false,
          "description": "Hide unsupported (unmapped) emoji from workspace scan results."
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Amaan9136/emoji-to-react-icons-vs-code"
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "bundle": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --target=node20",
    "vscode:prepublish": "npm run bundle"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "emoji-regex": "^10.4.0"
  }
}